<!DOCTYPE html>
<html lang="cs" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OAKM Hodnocení</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        /* --- 1. WOW FONT A POZADÍ --- */
        body {
            font-family: 'Poppins', sans-serif !important;
            /* Jemný kruhový přechod na pozadí místo čisté černé */
            background: radial-gradient(circle at top right, #1a0004 0%, #0a0a0a 40%, #000000 100%);
            min-height: 100vh;
        }

        /* --- 2. OAKM TLAČÍTKA S NEON EFEKTEM --- */
        .btn-oakm, .badge-oakm {
            background: linear-gradient(135deg, #e60023, #ff1a3c) !important;
            border: none !important;
            color: #ffffff !important;
            opacity: 1 !important;
            box-shadow: 0 4px 15px rgba(230, 0, 35, 0.3); /* Jemný stín v základu */
            transition: all 0.3s ease;
        }
        .btn-oakm:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 25px rgba(230, 0, 35, 0.6); /* Zářivý stín při najetí */
        }

        .btn-outline-oakm {
            color: #ff1a3c !important;
            border: 2px solid #e60023 !important;
            background-color: transparent !important;
            transition: all 0.3s ease;
        }
        .btn-outline-oakm:hover {
            background-color: #e60023 !important;
            color: #ffffff !important;
            box-shadow: 0 0 20px rgba(230, 0, 35, 0.5);
            transform: translateY(-2px);
        }

        /* Hover pro bílá tlačítka v červené liště */
        .btn-header-white {
            color: #ffffff !important;
            border: 2px solid rgba(255, 255, 255, 0.7) !important;
            background-color: transparent !important;
            transition: all 0.3s ease;
        }
        .btn-header-white:hover {
            background-color: #ffffff !important;
            color: #e60023 !important;
            border-color: #ffffff !important;
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.5);
        }

        /* --- 3. SKLENĚNÉ KARTY (GLASSMORPHISM) --- */
        .card {
            background: rgba(25, 25, 25, 0.5) !important; /* Poloprůhledné pozadí */
            backdrop-filter: blur(10px); /* Rozmazání toho, co je za kartou */
            border: 1px solid rgba(255, 255, 255, 0.05) !important;
            border-radius: 20px !important;
            transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
            overflow: hidden;
        }
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8), 0 0 20px rgba(230, 0, 35, 0.15);
            border-color: rgba(230, 0, 35, 0.4) !important;
        }

        /* Vylepšení červené hlavičky */
        .custom-navbar {
            background: linear-gradient(90deg, #b3001b 0%, #e60023 50%, #ff1a3c 100%) !important;
            box-shadow: 0 10px 30px rgba(230, 0, 35, 0.3);
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg mb-5 border-0 custom-navbar">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
            
            <div class="me-3 bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; box-shadow: 0 0 15px rgba(255,255,255,0.4);">
                <svg viewBox="0 0 100 100" width="30" height="30">
                    <circle cx="50" cy="25" r="20" fill="#e60023"/>
                    <circle cx="25" cy="70" r="20" fill="#e60023"/>
                    <circle cx="75" cy="70" r="20" fill="#e60023"/>
                    <line x1="50" y1="25" x2="25" y2="70" stroke="#e60023" stroke-width="16"/>
                    <line x1="50" y1="25" x2="75" y2="70" stroke="#e60023" stroke-width="16"/>
                </svg>
            </div>
            
            <span class="text-white tracking-wide" style="font-size: 1.4rem; letter-spacing: 1px;">
                <span class="fw-bold">OAKM</span> <span style="opacity: 0.9; font-weight: 300;">Hodnocení</span>
            </span>
        </a>
        
        <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <% if (user) { %>
                    <li class="nav-item me-3">
                        <span class="nav-link text-white opacity-75">Ahoj, <%= user.username %></span>
                    </li>
                    <% if (user.role === 'admin') { %>
                        <li class="nav-item me-2">
                            <a class="nav-link btn btn-header-white btn-sm px-3 rounded-pill fw-bold" href="/admin/add-teacher">+ Přidat učitele</a>
                        </li>
                    <% } %>
                    <li class="nav-item">
                        <a class="nav-link btn btn-header-white fw-bold btn-sm px-4 rounded-pill" href="/logout">Odhlásit se</a>
                    </li>
                <% } else { %>
                    <li class="nav-item me-2">
                        <a class="nav-link btn btn-header-white fw-bold btn-sm px-4 rounded-pill" href="/login">Přihlášení</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-header-white fw-bold btn-sm px-4 rounded-pill" href="/register">Registrace</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="container">