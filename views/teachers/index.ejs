<%- include('../partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2>Seznam učitelů</h2>
    </div>
    <div class="col-md-6">
        <form action="/" method="GET" class="d-flex">
            <input type="text" name="search" class="form-control me-2" placeholder="Hledat učitele nebo předmět...">
            <button type="submit" class="btn btn-outline-oakm">Hledat</button>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    <% if (teachers.length > 0) { %>
        <% teachers.forEach(teacher => { %>
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <% if (teacher.image) { %>
                        <img src="/uploads/<%= teacher.image %>" class="card-img-top" alt="<%= teacher.name %>" style="height: 250px; object-fit: cover;">
                    <% } else { %>
                        <div class="card-img-top bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 250px;">
                            <span>Bez fotky</span>
                        </div>
                    <% } %>
                    <div class="card-body">
                        <h5 class="card-title"><%= teacher.name %></h5>
                        <p class="card-text text-muted">
                            <%= teacher.subjects.join(', ') %>
                        </p>
                        <a href="/teachers/<%= teacher._id %>" class="btn btn-oakm w-100">Zobrazit profil a recenze</a>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col-12">
            <div class="alert shadow-sm" style="background-color: #1a1a1a; border: 1px solid #333; border-left: 4px solid #e60023; color: #ffffff;">
                Zatím nebyli přidáni žádní učitelé, nebo hledaný výraz neodpovídá žádnému výsledku.
            </div>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>